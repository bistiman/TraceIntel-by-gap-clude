<UserControl x:Class="TraceIntel.UI.Views.DomainIntelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:TraceIntel.UI.Converters"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1100">

    <UserControl.Resources>
        <converters:InverseBoolConverter x:Key="InverseBoolConverter"/>
        <converters:StringEmptyToVisibilityConverter x:Key="StringEmptyToVisibilityConverter"/>
        <converters:RadioStringEqualsConverter x:Key="RadioStringEqualsConverter"/>

        <Style x:Key="PremiumRadio" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
        </Style>

        <Style x:Key="StopButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#E74C3C"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F75C4C"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ExportButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#27AE60"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#37BE70"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="RowBackground" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="AlternatingRowBackground" Value="{DynamicResource SurfaceElevatedBrush}"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#7C6FE4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="BorderBrush" Value="#383850"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <TabControl Background="{DynamicResource BackgroundBrush}" BorderThickness="0" Margin="0">
            <!-- ====================== -->
            <!-- SUB-TAB 1: DNS SCANNER -->
            <!-- ====================== -->
            <TabItem Header="DNS Scanner">
                <Grid Margin="0,10,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- DNS Target & Options Section -->
                    <Border Grid.Row="0"
                            Background="{DynamicResource SurfaceBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="16"
                            Margin="0,0,0,12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Left Column: Input and Mode -->
                            <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Vertical" Margin="0,0,12,0">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Text="Target Domain or IP" Foreground="{DynamicResource ForegroundBrush}" FontWeight="SemiBold"/>
                                    <TextBlock Text=" | Status: " Foreground="{DynamicResource SecondaryForegroundBrush}" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding DnsReconStatus}" Foreground="{DynamicResource PrimaryBrush}" FontWeight="Bold"/>
                                </StackPanel>
                                <Grid>
                                    <TextBox x:Name="DnsReconTargetInput" Height="40"
                                             Text="{Binding DnsReconTarget, UpdateSourceTrigger=PropertyChanged}"
                                             ToolTip="Enter target domain (e.g. google.com) or IP (e.g. 8.8.8.8) to discover DNS records"
                                             VerticalContentAlignment="Center"/>
                                    <TextBlock IsHitTestVisible="False" Margin="14,12,14,0" Foreground="{DynamicResource SecondaryForegroundBrush}"
                                               Text="Example: google.com or 8.8.8.8"
                                               Visibility="{Binding DnsReconTarget, Converter={StaticResource StringEmptyToVisibilityConverter}}"/>
                                </Grid>
                                
                                <!-- DNS Scan Mode selector -->
                                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                    <TextBlock Text="Scan Mode: " Foreground="{DynamicResource ForegroundBrush}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <RadioButton Content="Quick" Style="{StaticResource PremiumRadio}" VerticalAlignment="Center"
                                                 IsChecked="{Binding DnsScanMode, Converter={StaticResource RadioStringEqualsConverter}, ConverterParameter=Standard}"/>
                                    <RadioButton Content="Deep" Style="{StaticResource PremiumRadio}" VerticalAlignment="Center"
                                                 IsChecked="{Binding DnsScanMode, Converter={StaticResource RadioStringEqualsConverter}, ConverterParameter=Deep}"/>
                                    <RadioButton Content="Custom" Style="{StaticResource PremiumRadio}" VerticalAlignment="Center"
                                                 IsChecked="{Binding DnsScanMode, Converter={StaticResource RadioStringEqualsConverter}, ConverterParameter=Custom}"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Middle Column: Query Types (Checkboxes for Complete Custom mode) -->
                            <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Vertical" Margin="0,0,12,0"
                                        IsEnabled="{Binding DnsScanMode, Converter={StaticResource RadioStringEqualsConverter}, ConverterParameter=Custom}">
<TextBlock Text="Manual Record Selection (Custom Mode)" Foreground="{DynamicResource ForegroundBrush}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                
                                <UniformGrid Columns="5" Rows="2">
                                    <CheckBox Content="A" Foreground="{DynamicResource ForegroundBrush}" Margin="0,2,0,2" IsChecked="{Binding DnsQueryA}"/>
                                    <CheckBox Content="AAAA" Foreground="White" Margin="0,2,0,2" IsChecked="{Binding DnsQueryAAAA}"/>
                                    <CheckBox Content="MX" Foreground="White" Margin="0,2,0,2" IsChecked="{Binding DnsQueryMX}"/>
                                    <CheckBox Content="NS" Foreground="White" Margin="0,2,0,2" IsChecked="{Binding DnsQueryNS}"/>
                                    <CheckBox Content="CNAME" Foreground="White" Margin="0,2,0,2" IsChecked="{Binding DnsQueryCNAME}"/>
                                    <CheckBox Content="TXT" Foreground="White" Margin="0,2,0,2" IsChecked="{Binding DnsQueryTXT}"/>
                                    <CheckBox Content="SOA" Foreground="White" Margin="0,2,0,2" IsChecked="{Binding DnsQuerySOA}"/>
                                    <CheckBox Content="SRV" Foreground="White" Margin="0,2,0,2" IsChecked="{Binding DnsQuerySRV}"/>
                                    <CheckBox Content="CAA" Foreground="White" Margin="0,2,0,2" IsChecked="{Binding DnsQueryCAA}"/>
                                    <CheckBox Content="AXFR" Foreground="{DynamicResource ForegroundBrush}" Margin="0,2,0,2" IsChecked="{Binding DnsQueryAXFR}" ToolTip="Attempt authoritative zone transfer"/>
                                </UniformGrid>

                                <!-- Subdomain brute force and Custom DNS server options -->
                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <CheckBox Content="Brute Force Subdomains" Foreground="{DynamicResource WarningBrush}" VerticalAlignment="Center" IsChecked="{Binding DnsBruteForce}"
                                              ToolTip="Probes common subdomains (e.g. mail, www, ftp) to discover hidden hosts"/>
                                    <TextBlock Text=" | Custom Resolver IP:" Foreground="{DynamicResource ForegroundBrush}" VerticalAlignment="Center" Margin="10,0,6,0"/>
                                    <TextBox Height="28" Width="130" Padding="4,2" Text="{Binding DnsCustomServer, UpdateSourceTrigger=PropertyChanged}"
                                             ToolTip="Optional: Specify a custom DNS server like 8.8.8.8 to bypass local cache"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Right Column: Commands -->
                            <StackPanel Grid.Row="0" Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Bottom">
                                <Button Content="Scan DNS" Command="{Binding StartDnsReconCommand}" Style="{StaticResource BaseButton}" Width="120" Height="40" Margin="0,0,8,0"/>
                                <Button Content="Stop" Command="{Binding StopDnsReconCommand}" Style="{StaticResource DangerButton}" Width="80" Height="40" Margin="0,0,8,0"/>
                                <Button Content="Export" Command="{Binding ExportDnsReconCommand}" Style="{StaticResource SuccessButton}" Width="110" Height="40"/>
                            </StackPanel>

                            <!-- Bottom Row: Inline Filter Search -->
                            <Grid Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="300"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Filter Search: " Foreground="#B8B8D8" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <TextBox Grid.Column="1" Height="32" Padding="6,4" Text="{Binding DnsReconSearchText, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="Instant search through type, domain, value, details..."/>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- DNS Records Display Area -->
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Records Grid -->
                        <DataGrid Grid.Column="0"
                                  x:Name="DnsReconDataGrid"
                                  ItemsSource="{Binding DnsRecordsView}"
                                  SelectedItem="{Binding SelectedDnsRecord}"
                                  AutoGenerateColumns="False"
                                  CanUserSortColumns="True"
                                  HeadersVisibility="Column"
                                  Margin="0,0,12,0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Type" Binding="{Binding RecordType}" Width="100" FontWeight="Bold"/>
                                <DataGridTextColumn Header="Domain Name" Binding="{Binding Name}" Width="1.5*" />
                                <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="2*" />
                                <DataGridTextColumn Header="Details / Attributes" Binding="{Binding Details}" Width="2*" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- Detail Panel -->
                        <Border Grid.Column="1"
                                Background="{DynamicResource SurfaceBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="16">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0"
                                           Text="DNS Record Inspector"
                                           FontSize="16"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource PrimaryBrush}"
                                           Margin="0,0,0,12"/>

                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                    <StackPanel>
                                        <TextBlock Text="Record Type:" Foreground="{DynamicResource SecondaryForegroundBrush}" FontSize="12" Margin="0,0,0,2"/>
                                        <TextBlock Text="{Binding SelectedDnsRecord.RecordType}" Foreground="{DynamicResource ForegroundBrush}" FontSize="14" FontWeight="Bold" Margin="0,0,0,12"/>

                                        <TextBlock Text="Domain / Host:" Foreground="{DynamicResource SecondaryForegroundBrush}" FontSize="12" Margin="0,0,0,2"/>
                                        <TextBlock Text="{Binding SelectedDnsRecord.Name}" Foreground="{DynamicResource ForegroundBrush}" FontSize="14" Margin="0,0,0,12" TextWrapping="Wrap"/>

                                        <TextBlock Text="IP / Target Value:" Foreground="{DynamicResource SecondaryForegroundBrush}" FontSize="12" Margin="0,0,0,2"/>
                                        <TextBox IsReadOnly="True"
                                                 Background="{DynamicResource SurfaceBrush}"
                                                 BorderThickness="0"
                                                 Text="{Binding SelectedDnsRecord.Value, Mode=OneWay}"
                                                 FontSize="14"
                                                 Foreground="{DynamicResource ForegroundBrush}"
                                                 TextWrapping="Wrap"
                                                 Padding="4"
                                                 Margin="0,0,0,12"/>

                                        <TextBlock Text="Parsed Properties &amp; TTL Details:" Foreground="{DynamicResource SecondaryForegroundBrush}" FontSize="12" Margin="0,0,0,2"/>
                                        <TextBox IsReadOnly="True"
                                                 Background="{DynamicResource SurfaceBrush}"
                                                 BorderThickness="0"
                                                 Height="180"
                                                 Text="{Binding SelectedDnsRecord.Details, Mode=OneWay}"
                                                 FontSize="14"
                                                 Foreground="{DynamicResource ForegroundBrush}"
                                                 TextWrapping="Wrap"
                                                 VerticalScrollBarVisibility="Auto"
                                                 Padding="6"
                                                 AcceptsReturn="True"/>

                                        <Button Content="📋 Copy Value" 
                                                Command="{Binding CopyDnsRecordValueCommand}" 
                                                HorizontalAlignment="Left" 
                                                Margin="0,10,0,0" 
                                                Width="130" Height="32" 
                                                FontWeight="Bold"
                                                ToolTip="Copy the selected record value to clipboard"/>
                                    </StackPanel>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ============================== -->
            <!-- SUB-TAB 2: INTERACTIVE NSLOOKUP -->
            <!-- ============================== -->
            <TabItem Header="Interactive NSLOOKUP">
                <Grid Margin="0,10,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="10" Padding="16" Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Domain Query -->
                            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                <TextBlock Text="Query Host / IP" Foreground="{DynamicResource ForegroundBrush}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <TextBox Height="40" Text="{Binding NslookupTarget, UpdateSourceTrigger=PropertyChanged}" ToolTip="Enter host (e.g. google.com)"/>
                            </StackPanel>

                            <!-- Query Type -->
                            <StackPanel Grid.Column="1" Margin="0,0,12,0">
                                <TextBlock Text="Record Type" Foreground="{DynamicResource ForegroundBrush}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <ComboBox Height="40" ItemsSource="{Binding NslookupRecordTypes}" SelectedItem="{Binding NslookupRecordType}"/>
                            </StackPanel>

                            <!-- DNS Server -->
                            <StackPanel Grid.Column="2" Margin="0,0,12,0">
                                <TextBlock Text="Resolver Server IP" Foreground="{DynamicResource ForegroundBrush}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <TextBox Height="40" Text="{Binding NslookupServer, UpdateSourceTrigger=PropertyChanged}" ToolTip="Optional: Custom DNS resolver (e.g. 1.1.1.1). Leave empty to use system default."/>
                            </StackPanel>

                            <!-- Query Command -->
                            <StackPanel Grid.Column="3" VerticalAlignment="Bottom">
                                <Button Content="Run NSLOOKUP" Command="{Binding RunNslookupCommand}" Width="160" Height="40"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1" Background="#1E1E2E" BorderBrush="#383850" BorderThickness="1" CornerRadius="10" Padding="16">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0" Margin="0,0,0,10">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                    <TextBlock Text="DNS Query Audit Output (dig format)" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}"/>
                                    <TextBlock Text=" | Status: " Foreground="#8888A8"/>
                                    <TextBlock Text="{Binding NslookupStatus}" Foreground="#F59E0B" FontWeight="Bold"/>
                                </StackPanel>
                                <Button Content="📋 Copy Output" 
                                        Command="{Binding CopyNslookupCommand}" 
                                        HorizontalAlignment="Right" 
                                        Width="140" Height="30" 
                                        FontWeight="Bold"
                                        ToolTip="Copy NSLOOKUP output to clipboard"/>
                            </Grid>
                            <TextBox Grid.Row="1" IsReadOnly="True" AcceptsReturn="True"
                                     Text="{Binding NslookupResultText}"
                                     Background="#11111B" BorderBrush="#383850" BorderThickness="1"
                                     Foreground="#A8E6A8" FontFamily="Consolas, Courier New" FontSize="13" Padding="12"
                                     VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                     TextWrapping="NoWrap"/>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ====================== -->
            <!-- SUB-TAB 3: WHOIS SCAN  -->
            <!-- ====================== -->
            <TabItem Header="WHOIS Lookup">
                <Grid Margin="0,10,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#1E1E2E" BorderBrush="#383850" BorderThickness="1" CornerRadius="10" Padding="14" Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Text="Query Target (Domain Name or IPv4 Address)" Foreground="{DynamicResource ForegroundBrush}" FontWeight="SemiBold"/>
                                    <TextBlock Text=" | Status: " Foreground="{DynamicResource SecondaryForegroundBrush}"/>
                                    <TextBlock Text="{Binding WhoisStatus}" Foreground="{DynamicResource WarningBrush}" FontWeight="Bold"/>
                                </StackPanel>
                                <TextBox Height="40" Text="{Binding WhoisTarget, UpdateSourceTrigger=PropertyChanged}" ToolTip="Enter a domain name (e.g. google.com) or an IP address (e.g. 8.8.8.8) to lookup registration information"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom">
                                <Button Content="Perform WHOIS" Command="{Binding StartWhoisCommand}" Width="160" Height="40" Margin="0,0,8,0"/>
                                <Button Content="Stop" Command="{Binding StopWhoisCommand}" Style="{StaticResource StopButton}" Width="80" Height="40"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1" Background="#1E1E2E" BorderBrush="#383850" BorderThickness="1" CornerRadius="10" Padding="16">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0" Margin="0,0,0,10">
                                <TextBlock Text="Domain Registration WHOIS Registry Output" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}" HorizontalAlignment="Left"/>
                                <Button Content="📋 Copy Output" 
                                        Command="{Binding CopyWhoisCommand}" 
                                        HorizontalAlignment="Right" 
                                        Width="140" Height="30" 
                                        FontWeight="Bold"
                                        ToolTip="Copy WHOIS output to clipboard"/>
                            </Grid>
                            <TextBox Grid.Row="1" IsReadOnly="True" AcceptsReturn="True"
                                     Text="{Binding WhoisResultText}"
                                     Background="#11111B" BorderBrush="#383850" BorderThickness="1"
                                     Foreground="{DynamicResource ForegroundBrush}" FontFamily="Consolas, Courier New" FontSize="13"
                                     VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" Padding="10"/>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
