<UserControl x:Class="TraceIntel.UI.Views.DomainIntelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:TraceIntel.UI.Converters"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1100">

    <UserControl.Resources>
        <converters:InverseBoolConverter x:Key="InverseBoolConverter"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:StringEmptyToVisibilityConverter x:Key="StringEmptyToVisibilityConverter"/>
        <converters:RadioStringEqualsConverter x:Key="RadioStringEqualsConverter"/>

        <Style TargetType="DataGrid" BasedOn="{StaticResource BaseDataGrid}">
            <Setter Property="RowBackground" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="AlternatingRowBackground" Value="{DynamicResource SurfaceElevatedBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="EnableRowVirtualization" Value="True"/>
        </Style>

        <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource BaseDataGridHeader}"/>

        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <TabControl Background="{DynamicResource BackgroundBrush}" BorderThickness="0">
            <TabControl.Resources>
                <Style TargetType="TabItem" BasedOn="{StaticResource AccentTabItem}"/>
            </TabControl.Resources>

            <!-- DNS Scanner -->
            <TabItem Header="DNS Scanner">
                <Grid Margin="0,16,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Step 1: Target -->
                    <Border Grid.Row="0" Style="{StaticResource PanelCard}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,20,0">
                                <TextBlock Text="1. Target" Style="{StaticResource SectionLabel}" Margin="0,0,0,8"/>
                                <Grid>
                                    <TextBox Height="42"
                                             Text="{Binding DnsReconTarget, UpdateSourceTrigger=PropertyChanged}"
                                             ToolTip="Domain (google.com) or IP (8.8.8.8)"/>
                                    <TextBlock IsHitTestVisible="False"
                                               Margin="14,12,14,0"
                                               Foreground="{DynamicResource MutedForegroundBrush}"
                                               Text="e.g. google.com or 8.8.8.8"
                                               Visibility="{Binding DnsReconTarget, Converter={StaticResource StringEmptyToVisibilityConverter}}"/>
                                </Grid>
                            </StackPanel>

                            <StackPanel Grid.Column="1" VerticalAlignment="Bottom">
                                <TextBlock Style="{StaticResource SectionLabel}" Margin="0,0,0,8">
                                    <Run Text="Status: "/>
                                    <Run Text="{Binding DnsReconStatus}" Foreground="{DynamicResource PrimaryBrush}" FontWeight="SemiBold"/>
                                </TextBlock>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Scan DNS"
                                            Command="{Binding StartDnsReconCommand}"
                                            Style="{StaticResource BaseButton}"
                                            Width="120" Height="40" Margin="0,0,8,0"/>
                                    <Button Content="Stop"
                                            Command="{Binding StopDnsReconCommand}"
                                            Style="{StaticResource DangerButton}"
                                            Width="80" Height="40" Margin="0,0,8,0"/>
                                    <ComboBox ItemsSource="{Binding ExportFormats}"
                                              SelectedItem="{Binding SelectedExportFormat}"
                                              Width="90" Height="40" Margin="0,0,8,0"/>
                                    <Button Content="Export"
                                            Command="{Binding ExportDnsReconCommand}"
                                            Style="{StaticResource SuccessButton}"
                                            Width="100" Height="40"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Step 2: Scan options -->
                    <Border Grid.Row="1" Style="{StaticResource PanelCard}" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="2. Scan profile &amp; record types" Style="{StaticResource SectionLabel}" Margin="0,0,0,12"/>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                <RadioButton Content="Quick"
                                             Margin="0,0,16,0"
                                             IsChecked="{Binding DnsScanMode, Converter={StaticResource RadioStringEqualsConverter}, ConverterParameter=Standard}"/>
                                <RadioButton Content="Deep"
                                             Margin="0,0,16,0"
                                             IsChecked="{Binding DnsScanMode, Converter={StaticResource RadioStringEqualsConverter}, ConverterParameter=Deep}"/>
                                <RadioButton Content="Custom"
                                             IsChecked="{Binding DnsScanMode, Converter={StaticResource RadioStringEqualsConverter}, ConverterParameter=Custom}"/>
                                <TextBlock Margin="20,0,0,0"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource MutedForegroundBrush}"
                                           FontSize="11"
                                           Text="Quick: core records · Deep: all types + AXFR + brute force · Custom: pick types"/>
                            </StackPanel>

                            <Border Background="{DynamicResource SurfaceElevatedBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="14"
                                    IsEnabled="{Binding IsScanOptionsReadOnly, Converter={StaticResource InverseBoolConverter}}">
                                <StackPanel>
                                    <UniformGrid Columns="5" Rows="2">
                                        <CheckBox Content="A" Margin="0,4" IsChecked="{Binding DnsQueryA}"/>
                                        <CheckBox Content="AAAA" Margin="0,4" IsChecked="{Binding DnsQueryAAAA}"/>
                                        <CheckBox Content="MX" Margin="0,4" IsChecked="{Binding DnsQueryMX}"/>
                                        <CheckBox Content="NS" Margin="0,4" IsChecked="{Binding DnsQueryNS}"/>
                                        <CheckBox Content="CNAME" Margin="0,4" IsChecked="{Binding DnsQueryCNAME}"/>
                                        <CheckBox Content="TXT" Margin="0,4" IsChecked="{Binding DnsQueryTXT}"/>
                                        <CheckBox Content="SOA" Margin="0,4" IsChecked="{Binding DnsQuerySOA}"/>
                                        <CheckBox Content="SRV" Margin="0,4" IsChecked="{Binding DnsQuerySRV}"/>
                                        <CheckBox Content="CAA" Margin="0,4" IsChecked="{Binding DnsQueryCAA}"/>
                                        <CheckBox Content="AXFR" Margin="0,4" IsChecked="{Binding DnsQueryAXFR}" ToolTip="Zone transfer attempt"/>
                                    </UniformGrid>

                                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                        <CheckBox Content="Brute-force subdomains"
                                                  VerticalAlignment="Center"
                                                  IsChecked="{Binding DnsBruteForce}"/>
                                        <TextBlock Text="Custom resolver:"
                                                   Margin="20,0,8,0"
                                                   VerticalAlignment="Center"
                                                   Style="{StaticResource SectionLabel}"/>
                                        <TextBox Width="160"
                                                 Height="36"
                                                 Text="{Binding DnsCustomServer, UpdateSourceTrigger=PropertyChanged}"
                                                 ToolTip="IP or hostname (e.g. 8.8.8.8 or dns.google). Uses Settings default if empty."/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Grid Margin="0,14,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="280"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="Filter results:"
                                           VerticalAlignment="Center"
                                           Style="{StaticResource SectionLabel}"
                                           Margin="0,0,10,0"/>
                                <TextBox Grid.Column="1"
                                         Height="36"
                                         Text="{Binding DnsReconSearchText, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="Search type, name, value, or details"/>
                                <TextBlock Grid.Column="2"
                                           Margin="16,0,0,0"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource MutedForegroundBrush}">
                                    <Run Text="{Binding DnsRecordCount, Mode=OneWay}"/>
                                    <Run Text=" record(s)"/>
                                </TextBlock>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Step 3: Results -->
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2.2*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Style="{StaticResource CardBorder}"
                                Margin="0,0,12,0"
                                Padding="0">
                            <Grid>
                                <ProgressBar Height="3"
                                             VerticalAlignment="Top"
                                             Style="{StaticResource BaseProgressBar}"
                                             IsIndeterminate="True"
                                             Visibility="{Binding IsDnsReconRunning, Converter={StaticResource BoolToVisibilityConverter}}"/>

                                <DataGrid x:Name="DnsReconDataGrid"
                                          ItemsSource="{Binding DnsRecordsView}"
                                          SelectedItem="{Binding SelectedDnsRecord}"
                                          Margin="0,4,0,0"
                                          BorderThickness="0"
                                          CanUserSortColumns="True">
                                    <DataGrid.GroupStyle>
                                        <GroupStyle>
                                            <GroupStyle.HeaderTemplate>
                                                <DataTemplate>
                                                    <Border Background="{DynamicResource SurfaceElevatedBrush}"
                                                            BorderBrush="{DynamicResource BorderBrush}"
                                                            BorderThickness="0,0,0,1"
                                                            Padding="12,8"
                                                            Margin="0,4,0,0">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="{Binding Name}"
                                                                       FontWeight="Bold"
                                                                       Foreground="{DynamicResource PrimaryBrush}"
                                                                       FontSize="13"/>
                                                            <TextBlock Text="{Binding ItemCount, StringFormat='  ({0})'}"
                                                                       Foreground="{DynamicResource SecondaryForegroundBrush}"
                                                                       FontSize="12"
                                                                       Margin="4,0,0,0"/>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </GroupStyle.HeaderTemplate>
                                            <GroupStyle.ContainerStyle>
                                                <Style TargetType="{x:Type GroupItem}">
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="{x:Type GroupItem}">
                                                                <StackPanel>
                                                                    <ContentPresenter Content="{TemplateBinding Content}"/>
                                                                    <ItemsPresenter/>
                                                                </StackPanel>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </GroupStyle.ContainerStyle>
                                        </GroupStyle>
                                    </DataGrid.GroupStyle>
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="1.4*"/>
                                        <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="1.6*"/>
                                        <DataGridTextColumn Header="Details" Binding="{Binding Details}" Width="2*"/>
                                    </DataGrid.Columns>
                                </DataGrid>

                                <Border Background="{DynamicResource SurfaceBrush}">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding HasDnsRecords}" Value="False"/>
                                                        <Condition Binding="{Binding IsDnsReconRunning}" Value="False"/>
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </MultiDataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="360">
                                        <TextBlock Text="No DNS results yet"
                                                   FontSize="16"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,0,0,8"/>
                                        <TextBlock Text="Enter a target and run a scan. Results are grouped by record type (A, MX, NS, etc.)."
                                                   TextAlignment="Center"
                                                   Foreground="{DynamicResource SecondaryForegroundBrush}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>

                        <Border Grid.Column="1" Style="{StaticResource CardBorder}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0"
                                           Text="Record inspector"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryBrush}"
                                           Margin="0,0,0,12"/>

                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                    <StackPanel>
                                        <TextBlock Text="Type" Style="{StaticResource SectionLabel}" Margin="0,0,0,4"/>
                                        <TextBlock Text="{Binding SelectedDnsRecord.RecordType}" FontWeight="SemiBold" Margin="0,0,0,12"/>

                                        <TextBlock Text="Name" Style="{StaticResource SectionLabel}" Margin="0,0,0,4"/>
                                        <TextBlock Text="{Binding SelectedDnsRecord.Name}" TextWrapping="Wrap" Margin="0,0,0,12"/>

                                        <TextBlock Text="Value" Style="{StaticResource SectionLabel}" Margin="0,0,0,4"/>
                                        <TextBox IsReadOnly="True"
                                                 BorderThickness="0"
                                                 Background="Transparent"
                                                 Text="{Binding SelectedDnsRecord.Value, Mode=OneWay}"
                                                 TextWrapping="Wrap"
                                                 Margin="0,0,0,12"/>

                                        <TextBlock Text="Details" Style="{StaticResource SectionLabel}" Margin="0,0,0,4"/>
                                        <TextBox IsReadOnly="True"
                                                 Style="{StaticResource ConsoleTextBox}"
                                                 Height="160"
                                                 Text="{Binding SelectedDnsRecord.Details, Mode=OneWay}"/>

                                        <Button Content="Copy value"
                                                Command="{Binding CopyDnsRecordValueCommand}"
                                                Style="{StaticResource BaseButton}"
                                                HorizontalAlignment="Left"
                                                Margin="0,12,0,0"
                                                Width="120" Height="34"/>
                                    </StackPanel>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- NSLOOKUP -->
            <TabItem Header="NSLOOKUP">
                <Grid Margin="0,16,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource PanelCard}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                <TextBlock Text="Host / IP" Style="{StaticResource SectionLabel}" Margin="0,0,0,8"/>
                                <TextBox Height="40" Text="{Binding NslookupTarget, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="0,0,12,0">
                                <TextBlock Text="Record type" Style="{StaticResource SectionLabel}" Margin="0,0,0,8"/>
                                <ComboBox Height="40" ItemsSource="{Binding NslookupRecordTypes}" SelectedItem="{Binding NslookupRecordType}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2" Margin="0,0,12,0">
                                <TextBlock Text="Resolver (optional)" Style="{StaticResource SectionLabel}" Margin="0,0,0,8"/>
                                <TextBox Height="40" Text="{Binding NslookupServer, UpdateSourceTrigger=PropertyChanged}" ToolTip="IP or hostname"/>
                            </StackPanel>

                            <StackPanel Grid.Column="3" VerticalAlignment="Bottom">
                                <TextBlock Style="{StaticResource StatusBadge}" Margin="0,0,0,8" Text="{Binding NslookupStatus}"/>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Run query" Command="{Binding RunNslookupCommand}" Style="{StaticResource BaseButton}" Width="120" Height="40" Margin="0,0,8,0"/>
                                    <Button Content="Stop" Command="{Binding StopNslookupCommand}" Style="{StaticResource DangerButton}" Width="80" Height="40"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1" Style="{StaticResource CardBorder}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0" Margin="0,0,0,10">
                                <TextBlock Text="Query output" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryBrush}"/>
                                <Button Content="Copy output"
                                        Command="{Binding CopyNslookupCommand}"
                                        Style="{StaticResource BaseButton}"
                                        HorizontalAlignment="Right"
                                        Width="120" Height="32"/>
                            </Grid>
                            <TextBox Grid.Row="1" Style="{StaticResource ConsoleTextBox}" Text="{Binding NslookupResultText, Mode=OneWay}"/>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- WHOIS -->
            <TabItem Header="WHOIS">
                <Grid Margin="0,16,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource PanelCard}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                <TextBlock Style="{StaticResource SectionLabel}" Margin="0,0,0,8">
                                    <Run Text="Domain or IP · "/>
                                    <Run Text="{Binding WhoisStatus}" Foreground="{DynamicResource WarningBrush}"/>
                                </TextBlock>
                                <TextBox Height="40" Text="{Binding WhoisTarget, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom">
                                <Button Content="Lookup WHOIS" Command="{Binding StartWhoisCommand}" Style="{StaticResource BaseButton}" Width="140" Height="40" Margin="0,0,8,0"/>
                                <Button Content="Stop" Command="{Binding StopWhoisCommand}" Style="{StaticResource DangerButton}" Width="80" Height="40"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1" Style="{StaticResource CardBorder}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Button Grid.Row="0"
                                    Content="Copy output"
                                    Command="{Binding CopyWhoisCommand}"
                                    Style="{StaticResource BaseButton}"
                                    HorizontalAlignment="Right"
                                    Width="120" Height="32"
                                    Margin="0,0,0,10"/>
                            <TextBox Grid.Row="1"
                                     Style="{StaticResource ConsoleTextBox}"
                                     Foreground="{DynamicResource ForegroundBrush}"
                                     Text="{Binding WhoisResultText, Mode=OneWay}"/>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
