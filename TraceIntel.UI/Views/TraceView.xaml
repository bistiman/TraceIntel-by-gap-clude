<UserControl x:Class="TraceIntel.UI.Views.TraceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:TraceIntel.UI.Converters"
             xmlns:local="clr-namespace:TraceIntel.UI.Views"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1100">

    <UserControl.Resources>
        <converters:BoolToStatusConverter x:Key="BoolToStatusConverter"/>
        <converters:InverseBoolConverter x:Key="InverseBoolConverter"/>
        <converters:JoinConverter x:Key="JoinConverter"/>
        <converters:StringEmptyToVisibilityConverter x:Key="StringEmptyToVisibilityConverter"/>
        <converters:RadioStringEqualsConverter x:Key="RadioStringEqualsConverter"/>
        <converters:ProgressBarWidthConverter x:Key="ProgressBarWidthConverter"/>
        <converters:HopStatusBrushConverter x:Key="HopStatusBrushConverter"/>

        <!-- Global TextBlock Style for consistent text handling -->
        <Style TargetType="TextBlock">
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Local TextBox override — extends global theme (preserves CornerRadius, CaretBrush, template) -->
        <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <DataTemplate x:Key="HopColumnHeaderTemplate">
            <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                <TextBlock Text="{Binding HopNumber, StringFormat=Hop {0}}"
                           FontWeight="SemiBold"
                           FontSize="11"
                           Foreground="White"/>
                <TextBox Height="26"
                          MinHeight="26"
                          Margin="0,6,0,0"
                          Padding="6,3"
                          FontSize="11"
                          Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                          ToolTip="Filter this hop (IP)"
                          Tag="Filter hop..."/>
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="HopCellTemplate">
            <Border CornerRadius="5"
                    Padding="8,5"
                    Background="{Binding IsTimeout, Converter={StaticResource HopStatusBrushConverter}}"
                    ToolTip="{Binding IP}">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding IP}" 
                               Foreground="White"
                               FontSize="12"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{Binding LatencyText}"
                               Foreground="#D7D7FF"
                               FontSize="11"
                               Margin="8,0,0,0"/>
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="HopCellTemplatePrimary">
            <Border CornerRadius="6"
                    Padding="10,6"
                    Background="{Binding IsTimeout, Converter={StaticResource HopStatusBrushConverter}}"
                    ToolTip="{Binding IP}">
                <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                    <TextBlock Text="{Binding IP}"
                               Foreground="White"
                               FontWeight="SemiBold"
                               FontSize="12"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{Binding LatencyText}"
                               Foreground="#D7D7FF"
                               FontSize="11"
                               Margin="0,3,0,0"/>
                </StackPanel>
            </Border>
        </DataTemplate>

        <Style x:Key="PremiumRadio" TargetType="RadioButton">
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
        </Style>

        <Style x:Key="StopButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#E74C3C"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F75C4C"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ExportButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#27AE60"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#37BE70"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="RowBackground" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="AlternatingRowBackground" Value="{DynamicResource SurfaceElevatedBrush}"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="#2D2D3A"/>
            <Setter Property="MinHeight" Value="44"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsEarlyFail}" Value="True">
                    <Setter Property="Background" Value="#33262A"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#1a1a2e"/>
            <Setter Property="BorderThickness" Value="0,0,1,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridColumnHeader">
                        <Border x:Name="BackgroundBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <Grid Margin="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                  SnapsToDevicePixels="True"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter VerticalAlignment="Center"
                                              HorizontalAlignment="Left"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ProgressBar">
            <Setter Property="Height" Value="24"/>
            <Setter Property="Background" Value="#2D2D3A"/>
            <Setter Property="Foreground" Value="#6C5CE7"/>
            <Setter Property="BorderBrush" Value="#6C5CE7"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Input Section -->
            <RowDefinition Height="*"/>    <!-- Results Section -->
            <RowDefinition Height="Auto"/> <!-- Local Status -->
        </Grid.RowDefinitions>

        <!-- Input Section: Only visible in Traceroute Diagnostics -->
        <Border Grid.Row="0"
                Style="{StaticResource PanelCard}"
                Margin="0,0,0,24">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Targets (paste one per line, or comma/space separated)"
                               Style="{StaticResource SectionLabel}"
                               FontWeight="SemiBold"
                               FontSize="13"
                               Margin="0,0,0,10"
                               Foreground="{DynamicResource ForegroundBrush}"/>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Domains Input (paste-friendly) -->
                        <Grid Grid.Column="0">
                            <TextBox x:Name="TargetsInputBox"
                                     Text="{Binding DomainsInput, UpdateSourceTrigger=PropertyChanged}"
                                     AcceptsReturn="True"
                                     AcceptsTab="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Disabled"
                                     MinHeight="110"
                                     MaxHeight="170"
                                     FontSize="13"
                                     Tag="google.com&#x0a;8.8.8.8&#x0a;https://example.com/path"
                                     ToolTip="Examples: google.com | 8.8.8.8 | https://example.com/path"/>
                        </Grid>

                        <StackPanel Grid.Column="1" Margin="18,0,0,0" VerticalAlignment="Top">
                            <TextBlock Text="Trace Depth"
                                       Foreground="{DynamicResource SecondaryForegroundBrush}"
                                       FontWeight="SemiBold"
                                       FontSize="12"
                                       Margin="0,0,0,10"/>

                            <StackPanel Orientation="Vertical" Margin="0,0,0,12">
                                <RadioButton Content="5 Hops"
                                             Style="{StaticResource PremiumRadio}"
                                             IsChecked="{Binding HopMode, Converter={StaticResource RadioStringEqualsConverter}, ConverterParameter=5}"
                                             Margin="0,0,0,6"/>
                                <RadioButton Content="Complete"
                                             Style="{StaticResource PremiumRadio}"
                                             IsChecked="{Binding HopMode, Converter={StaticResource RadioStringEqualsConverter}, ConverterParameter=Complete}"
                                             Margin="0,0,0,6"/>
                                <RadioButton Content="Custom"
                                             Style="{StaticResource PremiumRadio}"
                                             IsChecked="{Binding HopMode, Converter={StaticResource RadioStringEqualsConverter}, ConverterParameter=Custom}"/>
                            </StackPanel>

                            <TextBox Text="{Binding CustomMaxHops, UpdateSourceTrigger=PropertyChanged}"
                                     Width="120"
                                     FontSize="13"
                                     VerticalContentAlignment="Center"
                                     IsEnabled="{Binding HopMode, Converter={StaticResource RadioStringEqualsConverter}, ConverterParameter=Custom}"
                                     ToolTip="Custom max hops (1-255)"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Grid.Row="2"
                               Margin="0,12,0,0"
                               Foreground="{DynamicResource SecondaryForegroundBrush}"
                               FontSize="11"
                               Text="Tip: Paste domains, IPs or URLs. Invalid entries are skipped automatically."/>
                </Grid>

                <!-- Actions -->
                <StackPanel Grid.Column="1" Margin="20,0,0,0" VerticalAlignment="Bottom">
                    <Button Content="Start Trace"
                            Command="{Binding StartCommand}"
                            Style="{StaticResource BaseButton}"
                            IsEnabled="{Binding IsRunning, Converter={StaticResource InverseBoolConverter}}"
                            Width="140" Height="40"
                            Margin="0,0,0,8"/>
                    <Button Content="Stop"
                            Command="{Binding StopCommand}"
                            Style="{StaticResource DangerButton}"
                            IsEnabled="{Binding IsRunning}"
                            Width="140" Height="40"
                            Margin="0,0,0,8"/>
                    <ComboBox ItemsSource="{Binding ExportFormats}"
                              SelectedItem="{Binding SelectedExportFormat}"
                              Width="140"
                              Margin="0,0,0,8"/>
                    <Button Content="Export Data"
                            Command="{Binding ExportCommand}"
                            Style="{StaticResource SuccessButton}"
                            Width="140" Height="40"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Results tabs -->
        <TabControl Grid.Row="1" 
                    TabStripPlacement="Top" 
                    Margin="0,0,0,16" 
                    Background="{DynamicResource BackgroundBrush}" 
                    BorderThickness="0"
                    Padding="0">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Foreground" Value="{DynamicResource SecondaryForegroundBrush}"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Padding" Value="20,12"/>
                    <Setter Property="Margin" Value="0,0,8,0"/>
                    <Setter Property="Cursor" Value="Hand"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border Name="Border"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="0,0,0,2"
                                        Padding="{TemplateBinding Padding}"
                                        SnapsToDevicePixels="True">
                                    <ContentPresenter ContentSource="Header"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Center"
                                                      RecognizesAccessKey="True"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter Property="Foreground" Value="{DynamicResource SecondaryForegroundBrush}"/>
                                        <Setter Property="Opacity" Value="0.5"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.Resources>
            <TabItem Header="Routing Table">
                <Grid Margin="0,16,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Search and Info Section -->
                    <Border Grid.Row="0"
                            Background="{DynamicResource SurfaceElevatedBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="0,0,0,16"
                            Margin="0,0,0,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Orientation="Vertical" VerticalAlignment="Top">
                                <TextBlock Text="Search Results (domain / destination / hop IP)"
                                           Style="{StaticResource SectionLabel}"
                                           FontWeight="SemiBold"
                                           FontSize="13"
                                           Margin="0,0,0,8"
                                           Foreground="{DynamicResource ForegroundBrush}"/>
                                <TextBox x:Name="GlobalSearchBox"
                                         FontSize="13"
                                         Tag="Search domain, dest, or hop IP..."
                                         Text="{Binding GlobalSearchText, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="Search across domain, destination, and all hops (Ctrl+F to focus)"
                                         VerticalContentAlignment="Center"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1"
                                        Margin="24,0,0,0"
                                        VerticalAlignment="Center">
                                <Border Background="{DynamicResource SurfaceBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1"
                                        Padding="12,8"
                                        CornerRadius="6">
                                    <TextBlock Foreground="{DynamicResource SecondaryForegroundBrush}"
                                               FontSize="12">
                                        <Run Text="Columns: "/>
                                        <Run Text="{Binding HopColumnCount, Mode=OneWay}" 
                                             FontWeight="SemiBold"
                                             Foreground="{DynamicResource PrimaryBrush}"/>
                                        <Run Text=" hops"/>
                                    </TextBlock>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Data Grid -->
                    <DataGrid x:Name="RoutingDataGrid"
                               Grid.Row="1"
                               ItemsSource="{Binding RoutingRowsView}"
                               AutoGenerateColumns="False"
                               CanUserSortColumns="True"
                               ClipboardCopyMode="ExcludeHeader"
                               SelectionUnit="CellOrRowHeader"
                               SelectionMode="Extended"
                               EnableRowVirtualization="True"
                               EnableColumnVirtualization="True"
                               VirtualizingPanel.IsVirtualizing="True"
                               VirtualizingPanel.VirtualizationMode="Recycling"
                               ScrollViewer.CanContentScroll="True"
                               ColumnHeaderHeight="70"
                               RowHeaderWidth="0"
                               FrozenColumnCount="3"
                               HeadersVisibility="Column"
                               CanUserResizeColumns="True"
                               CanUserReorderColumns="True"
                               CanUserResizeRows="False"
                               BorderBrush="{DynamicResource BorderBrush}"
                               BorderThickness="1">
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Copy" Command="Copy" />
                                <MenuItem Header="Copy with headers" Click="CopyWithHeaders_Click" />
                                <Separator />
                                <MenuItem Header="Perform DNS Recon" 
                                          Command="{Binding DataContext.RunReconFromTraceCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                          CommandParameter="{Binding SelectedItem.Domain, RelativeSource={RelativeSource AncestorType=DataGrid}}"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.RowDetailsTemplate>
                            <DataTemplate>
                                <Border Background="#242433" Padding="16" CornerRadius="8" Margin="12,8,12,8">
                                    <StackPanel Orientation="Vertical">
                                        <TextBlock Text="Hop Details" 
                                                   FontWeight="SemiBold" 
                                                   FontSize="12"
                                                   Foreground="#C9C9E6"
                                                   Margin="0,0,0,8"/>
                                        <ItemsControl ItemsSource="{Binding Hops}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border CornerRadius="5"
                                                            Margin="0,0,10,10"
                                                            Padding="10,6"
                                                            Background="{Binding IsTimeout, Converter={StaticResource HopStatusBrushConverter}}"
                                                            ToolTip="{Binding HopNumber, StringFormat=Hop {0}}">
                                                        <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                                                            <TextBlock Foreground="White"
                                                                       FontSize="11"
                                                                       FontWeight="SemiBold"
                                                                       Text="{Binding IP}"
                                                                       TextTrimming="CharacterEllipsis"/>
                                                            <TextBlock Text="{Binding LatencyText}" 
                                                                       Foreground="#D7D7FF"
                                                                       FontSize="10"
                                                                       Margin="0,2,0,0"/>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </DataGrid.RowDetailsTemplate>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="By Hop">
                <Grid Margin="0,16,0,0">
                    <!-- Empty state -->
                    <Border Background="{DynamicResource SurfaceElevatedBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="32">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasHopSections}" Value="False">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    MaxWidth="420">
                            <TextBlock Text="No hop data yet"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource ForegroundBrush}"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,8"/>
                            <TextBlock Text="Run a trace to see each hop grouped with the domains and IPs that reached it."
                                       FontSize="12"
                                       Foreground="{DynamicResource SecondaryForegroundBrush}"
                                       TextWrapping="Wrap"
                                       TextAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Hop cards -->
                    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto"
                                  PanningMode="Both">
                        <ScrollViewer.Style>
                            <Style TargetType="ScrollViewer">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasHopSections}" Value="False">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ScrollViewer.Style>
                        <ItemsControl ItemsSource="{Binding HopSections}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>

                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource SurfaceBrush}"
                                            BorderBrush="{DynamicResource PrimaryBrush}"
                                            BorderThickness="1"
                                            CornerRadius="10"
                                            Margin="0,0,16,16"
                                            Padding="18"
                                            Width="360"
                                            VerticalAlignment="Top">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <StackPanel Grid.Row="0" Orientation="Vertical" Margin="0,0,0,12">
                                                <TextBlock FontSize="16"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource PrimaryBrush}"
                                                           Text="{Binding HopNumber, StringFormat=Hop {0}}"/>
                                                <TextBlock FontSize="11"
                                                           Foreground="{DynamicResource SecondaryForegroundBrush}"
                                                           Margin="0,4,0,0">
                                                    <Run Text="{Binding RecordCount, Mode=OneWay}"/>
                                                    <Run Text=" record(s)"/>
                                                </TextBlock>
                                            </StackPanel>

                                            <TextBox Grid.Row="1"
                                                     Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                                                     Margin="0,4,0,0"
                                                     MinHeight="28"
                                                     Tag="Filter IP or host..."
                                                     ToolTip="Filter records by IP or Hostname"/>

                                            <DataGrid Grid.Row="2"
                                                      ItemsSource="{Binding RowsView}"
                                                      HeadersVisibility="Column"
                                                      AutoGenerateColumns="False"
                                                      CanUserSortColumns="True"
                                                      CanUserResizeColumns="True"
                                                      CanUserResizeRows="False"
                                                      MaxHeight="320"
                                                      EnableRowVirtualization="True"
                                                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                                <DataGrid.Columns>
                                                    <DataGridTextColumn Header="Domain"
                                                                        Binding="{Binding Domain}"
                                                                        Width="*"
                                                                        MinWidth="100"/>
                                                    <DataGridTextColumn Header="IP"
                                                                        Binding="{Binding IP}"
                                                                        Width="140"
                                                                        MinWidth="120"/>
                                                </DataGrid.Columns>
                                            </DataGrid>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Status Bar Localized to Diagnostic Probe Progress -->
        <Border Grid.Row="2"
                Background="{DynamicResource SurfaceElevatedBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="16,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Status Info -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0">
                    <TextBlock Foreground="{DynamicResource SecondaryForegroundBrush}" FontSize="12" Margin="0,0,8,0">
                        <Run Text="Status:"/>
                    </TextBlock>
                    <TextBlock Text="{Binding Status}"
                               FontWeight="SemiBold" 
                               Foreground="{DynamicResource PrimaryBrush}"
                               FontSize="12"/>
                </StackPanel>

                <!-- Progress Bar -->
                <ProgressBar Grid.Column="1" 
                             Margin="0,0,20,0"
                             Height="22"
                             Style="{StaticResource BaseProgressBar}" 
                             Value="{Binding Progress}" 
                             Maximum="100"
                             VerticalAlignment="Center"/>

                <!-- Successful Traces Count -->
                <Border Grid.Column="2"
                        Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="5"
                        Padding="12,7"
                        Margin="0,0,12,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Foreground="{DynamicResource SecondaryForegroundBrush}" FontSize="11" Margin="0,0,6,0">
                            <Run Text="Traced:"/>
                        </TextBlock>
                        <TextBlock Text="{Binding SuccessfulTracesCount, Mode=OneWay}"
                                   FontWeight="SemiBold" 
                                   Foreground="{DynamicResource PrimaryBrush}"
                                   FontSize="11"/>
                    </StackPanel>
                </Border>

                <!-- Progress Percentage -->
                <Border Grid.Column="3"
                        Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="5"
                        Padding="12,7"
                        Margin="0,0,0,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Foreground="{DynamicResource SecondaryForegroundBrush}" FontSize="11" Margin="0,0,6,0">
                            <Run Text="Progress:"/>
                        </TextBlock>
                        <TextBlock Text="{Binding Progress, StringFormat={}{0:F1}%}"
                                   FontWeight="SemiBold" 
                                   Foreground="{DynamicResource PrimaryBrush}"
                                   FontSize="11"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
