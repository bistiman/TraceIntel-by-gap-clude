<UserControl x:Class="TraceIntel.UI.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1100">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="380"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Style="{StaticResource CardBorder}" Margin="0,0,16,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Engine configuration"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryBrush}"
                               Margin="0,0,0,20"/>

                    <TextBlock Text="Maximum concurrent traceroutes" Style="{StaticResource SectionLabel}" Margin="0,0,0,8"/>
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="60"/>
                        </Grid.ColumnDefinitions>
                        <Slider Grid.Column="0"
                                Minimum="1" Maximum="50"
                                TickFrequency="1" IsSnapToTickEnabled="True"
                                Value="{Binding SettingsParallelism}"
                                VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding SettingsParallelism}"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Grid>

                    <TextBlock Text="Traceroute / DNS timeout (ms)" Style="{StaticResource SectionLabel}" Margin="0,0,0,8"/>
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>
                        <Slider Grid.Column="0"
                                Minimum="500" Maximum="10000"
                                TickFrequency="100" IsSnapToTickEnabled="True"
                                Value="{Binding SettingsTimeoutMs}"
                                VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding SettingsTimeoutMs, StringFormat={}{0} ms}"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Grid>

                    <TextBlock Text="Default DNS resolver" Style="{StaticResource SectionLabel}" Margin="0,0,0,8"/>
                    <TextBox Height="42"
                             Text="{Binding SettingsDefaultDnsServer, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="Prefills DNS Recon custom resolver (e.g. 1.1.1.1)"/>
                    <TextBlock Text="Used when DNS Recon custom resolver is empty."
                               Foreground="{DynamicResource MutedForegroundBrush}"
                               FontSize="11"
                               Margin="0,6,0,20"/>

                    <CheckBox Content="Enable DNS &amp; IP geo cache lookups"
                              Margin="0,0,0,20"
                              IsChecked="{Binding SettingsEnableCache}"/>

                    <TextBlock Text="Default export path" Style="{StaticResource SectionLabel}" Margin="0,0,0,8"/>
                    <TextBox Height="42"
                             Text="{Binding SettingsDefaultExportPath, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <Border Grid.Column="1" Style="{StaticResource CardBorder}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Quick guide"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="{DynamicResource WarningBrush}"
                               Margin="0,0,0,16"/>

                    <TextBlock Text="Traceroute" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <TextBlock Text="Map network paths with ICMP probes. Use Quick (5 hops) for gateways or Complete for full paths."
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource SecondaryForegroundBrush}"
                               Margin="0,0,0,16"/>

                    <TextBlock Text="DNS Recon" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <TextBlock Text="Enumerate A, MX, NS, TXT, and more. Deep mode adds zone transfer and subdomain discovery."
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource SecondaryForegroundBrush}"
                               Margin="0,0,0,16"/>

                    <TextBlock Text="Ping tool" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <TextBlock Text="Continuous ICMP echo for latency monitoring."
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource SecondaryForegroundBrush}"/>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
