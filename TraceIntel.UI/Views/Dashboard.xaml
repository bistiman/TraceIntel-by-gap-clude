<UserControl x:Class="TraceIntel.UI.Views.Dashboard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1000">

    <Grid Background="#161622" Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" /> <!-- Tactical Header -->
            <RowDefinition Height="Auto" /> <!-- Metrics Cards -->
            <RowDefinition Height="1.4*" /> <!-- Charts -->
            <RowDefinition Height="1*" />   <!-- Live Cyber Stream -->
        </Grid.RowDefinitions>

        <!-- ====================== -->
        <!-- TACTICAL TITLE HEADER  -->
        <!-- ====================== -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="Telemetry Dashboard" FontSize="20" FontWeight="Bold" Foreground="White"/>
                <TextBlock Text="TACTICAL NETWORK RECONNAISSANCE &amp; THREAT TELEMETRY CONSOLE" FontSize="9" FontFamily="Consolas" Foreground="#6C5CE7" FontWeight="Bold" Margin="0,2,0,0"/>
            </StackPanel>
        </Grid>

        <!-- ====================== -->
        <!-- METRICS CARDS ROW      -->
        <!-- ====================== -->
        <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,16">
            
            <!-- Target Scanned Card -->
            <Border BorderBrush="#34344A" BorderThickness="1" CornerRadius="10" Margin="0,0,8,0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#1F1F30" Offset="0" />
                        <GradientStop Color="#151522" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <!-- Left Accent Bar -->
                    <Border Background="#6C5CE7" Width="4" HorizontalAlignment="Left" CornerRadius="4,0,0,4"/>
                    <StackPanel Margin="16,14,14,14">
                        <TextBlock Text="TOTAL TARGETS SCANNED" FontSize="9" Foreground="#8A8AB0" FontWeight="Bold"/>
                        <TextBlock Text="{Binding TotalTraced}" FontSize="28" FontWeight="Bold" Foreground="#9F8DFF" Margin="0,6,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Success Rate Card -->
            <Border BorderBrush="#34344A" BorderThickness="1" CornerRadius="10" Margin="8,0,8,0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#1F1F30" Offset="0" />
                        <GradientStop Color="#151522" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <!-- Left Accent Bar -->
                    <Border Background="#27AE60" Width="4" HorizontalAlignment="Left" CornerRadius="4,0,0,4"/>
                    <StackPanel Margin="16,14,14,14">
                        <TextBlock Text="SUCCESS RATE / ACTIVE" FontSize="9" Foreground="#8A8AB0" FontWeight="Bold"/>
                        <TextBlock Text="{Binding SuccessCount}" FontSize="28" FontWeight="Bold" Foreground="#2ECC71" Margin="0,6,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Average Hop Depth Card -->
            <Border BorderBrush="#34344A" BorderThickness="1" CornerRadius="10" Margin="8,0,8,0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#1F1F30" Offset="0" />
                        <GradientStop Color="#151522" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <!-- Left Accent Bar -->
                    <Border Background="#FFB020" Width="4" HorizontalAlignment="Left" CornerRadius="4,0,0,4"/>
                    <StackPanel Margin="16,14,14,14">
                        <TextBlock Text="AVERAGE HOP DEPTH" FontSize="9" Foreground="#8A8AB0" FontWeight="Bold"/>
                        <TextBlock Text="{Binding AvgHopDepth, StringFormat={}{0} Hops}" FontSize="28" FontWeight="Bold" Foreground="#F1C40F" Margin="0,6,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Early Failures Card -->
            <Border BorderBrush="#34344A" BorderThickness="1" CornerRadius="10" Margin="8,0,0,0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#1F1F30" Offset="0" />
                        <GradientStop Color="#151522" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <!-- Left Accent Bar -->
                    <Border Background="#E74C3C" Width="4" HorizontalAlignment="Left" CornerRadius="4,0,0,4"/>
                    <StackPanel Margin="16,14,14,14">
                        <TextBlock Text="EARLY PATH BLOCKS / FAILS" FontSize="9" Foreground="#8A8AB0" FontWeight="Bold"/>
                        <TextBlock Text="{Binding EarlyFailures}" FontSize="28" FontWeight="Bold" Foreground="#E74C3C" Margin="0,6,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

        </UniformGrid>

        <!-- ====================== -->
        <!-- CHARTS SECTION         -->
        <!-- ====================== -->
        <Grid Grid.Row="2" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3.2*" /> <!-- Latency Line Chart -->
                <ColumnDefinition Width="2*" /> <!-- DNS Record Type Distribution -->
            </Grid.ColumnDefinitions>

            <!-- Network Latency Cartesian Chart -->
            <Border Grid.Column="0" BorderBrush="#34344A" BorderThickness="1" CornerRadius="10" Padding="16" Margin="0,0,12,0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#1F1F30" Offset="0" />
                        <GradientStop Color="#151522" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="{Binding LatencyChartTitle}" FontSize="13" FontFamily="Consolas" FontWeight="Bold" Foreground="White" Margin="0,0,0,12"/>

                    <lvc:CartesianChart Grid.Row="1"
                                        Series="{Binding ActivitySeries}"
                                        XAxes="{Binding XAxes}"
                                        YAxes="{Binding YAxes}"
                                        LegendPosition="Hidden" />
                </Grid>
            </Border>

            <!-- DNS Records Distribution Pie Chart -->
            <Border Grid.Column="1" BorderBrush="#34344A" BorderThickness="1" CornerRadius="10" Padding="16">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#1F1F30" Offset="0" />
                        <GradientStop Color="#151522" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="DNS RECORD RATIO DISTRIBUTION" FontSize="13" FontFamily="Consolas" FontWeight="Bold" Foreground="White" Margin="0,0,0,12"/>

                    <lvc:PieChart Grid.Row="1"
                                  Series="{Binding DnsRecordSeries}"
                                  LegendPosition="Right" />
                </Grid>
            </Border>
        </Grid>

        <!-- ======================================= -->
        <!-- CYBER SECURITY REAL-TIME EVENT STREAM  -->
        <!-- ======================================= -->
        <Border Grid.Row="3" BorderBrush="#2B2B3C" BorderThickness="1" CornerRadius="10" Padding="14" Margin="0,0,0,0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#1B1B2C" Offset="0" />
                    <GradientStop Color="#111119" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                    <!-- Blinking indicator -->
                    <Ellipse x:Name="LiveIndicator" Width="8" Height="8" Fill="#FF3B30" Margin="0,0,8,0" VerticalAlignment="Center">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Style.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever">
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity" From="1" To="0.2" Duration="0:0:0.8" AutoReverse="True"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="LIVE SECURITY INTEL RECON LOG STREAM" FontSize="10" FontFamily="Consolas" FontWeight="Bold" Foreground="#A8A8C8" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Scrollable Console List -->
                <Border Grid.Row="1" CornerRadius="8" Background="#0A0A10" BorderBrush="#222232" BorderThickness="1">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="Transparent" Padding="12,10">
                        <ItemsControl ItemsSource="{Binding DataContext.ActivityLog, RelativeSource={RelativeSource AncestorType=Window}}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,2,0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <!-- Micro terminal prompt indicator -->
                                        <TextBlock Grid.Column="0" Text="❯" FontFamily="Consolas" FontSize="13" Foreground="#6C5CE7" Margin="0,0,8,0"/>
                                        <TextBlock Grid.Column="1" Text="{Binding}" FontFamily="Consolas, Courier New" FontSize="13" Foreground="#3BF520" TextWrapping="Wrap"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>