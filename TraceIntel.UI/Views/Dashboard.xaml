<UserControl x:Class="TraceIntel.UI.Views.Dashboard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1000">

    <Grid Background="{DynamicResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="1.4*"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>

        <!-- Metrics -->
        <UniformGrid Grid.Row="0" Columns="4" Margin="0,0,0,16">
            <Border Style="{StaticResource MetricCard}">
                <Grid>
                    <Border Background="{DynamicResource PrimaryBrush}" Width="4" HorizontalAlignment="Left" CornerRadius="4,0,0,4"/>
                    <StackPanel Margin="18,14,14,14">
                        <TextBlock Text="TOTAL SCANNED" FontSize="11" Foreground="{DynamicResource SecondaryForegroundBrush}" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding TotalTraced}" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource SecondaryBrush}" Margin="0,6,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Style="{StaticResource MetricCard}">
                <Grid>
                    <Border Background="{DynamicResource SuccessBrush}" Width="4" HorizontalAlignment="Left" CornerRadius="4,0,0,4"/>
                    <StackPanel Margin="18,14,14,14">
                        <TextBlock Text="SUCCESS COUNT" FontSize="11" Foreground="{DynamicResource SecondaryForegroundBrush}" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding SuccessCount}" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource SuccessBrush}" Margin="0,6,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Style="{StaticResource MetricCard}">
                <Grid>
                    <Border Background="{DynamicResource WarningBrush}" Width="4" HorizontalAlignment="Left" CornerRadius="4,0,0,4"/>
                    <StackPanel Margin="18,14,14,14">
                        <TextBlock Text="AVG HOP DEPTH" FontSize="11" Foreground="{DynamicResource SecondaryForegroundBrush}" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding AvgHopDepth, StringFormat={}{0} hops}" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource WarningBrush}" Margin="0,6,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Style="{StaticResource MetricCard}" Margin="0">
                <Grid>
                    <Border Background="{DynamicResource ErrorBrush}" Width="4" HorizontalAlignment="Left" CornerRadius="4,0,0,4"/>
                    <StackPanel Margin="18,14,14,14">
                        <TextBlock Text="PATH FAILURES" FontSize="11" Foreground="{DynamicResource SecondaryForegroundBrush}" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding EarlyFailures}" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource ErrorBrush}" Margin="0,6,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>
        </UniformGrid>

        <!-- History + Intel -->
        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3.2*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardBorder}" Margin="0,0,12,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Diagnostic task history"
                               Style="{StaticResource SectionLabel}"
                               Margin="0,0,0,12"/>
                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding CompletedTasks}"
                              Style="{StaticResource BaseDataGrid}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              BorderThickness="0"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="{DynamicResource BorderBrush}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Target" Binding="{Binding Domain}" Width="*"/>
                            <DataGridTextColumn Header="Resolved IP" Binding="{Binding ResolvedDestination}" Width="*"/>
                            <DataGridTextColumn Header="Hops" Binding="{Binding HopCount}" Width="60"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource CardBorder}">
                <StackPanel>
                    <TextBlock Text="Network intel" Style="{StaticResource SectionLabel}" Margin="0,0,0,16"/>
                    <StackPanel Margin="0,0,0,14">
                        <TextBlock Text="Local IP" FontSize="11" Foreground="{DynamicResource MutedForegroundBrush}"/>
                        <TextBlock Text="{Binding LocalIp}" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryBrush}" Margin="0,4,0,0"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,0,14">
                        <TextBlock Text="Default gateway" FontSize="11" Foreground="{DynamicResource MutedForegroundBrush}"/>
                        <TextBlock Text="{Binding Gateway}" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource SuccessBrush}" Margin="0,4,0,0"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,0,14">
                        <TextBlock Text="Primary DNS" FontSize="11" Foreground="{DynamicResource MutedForegroundBrush}"/>
                        <TextBlock Text="{Binding DnsServer}" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource WarningBrush}" Margin="0,4,0,0"/>
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="Network status" FontSize="11" Foreground="{DynamicResource MutedForegroundBrush}"/>
                        <TextBlock Text="{Binding NetworkStatus}" FontSize="15" FontWeight="SemiBold" Margin="0,4,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Activity log -->
        <Border Grid.Row="2" Style="{StaticResource CardBorder}" Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                    <Ellipse Width="8" Height="8" Fill="{DynamicResource ErrorBrush}" Margin="0,0,8,0" VerticalAlignment="Center">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Style.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever">
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity" From="1" To="0.3" Duration="0:0:0.9" AutoReverse="True"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="Live activity log" Style="{StaticResource SectionLabel}"/>
                </StackPanel>

                <Border Grid.Row="1"
                        CornerRadius="8"
                        Background="{DynamicResource ConsoleBackgroundBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12,10">
                        <ItemsControl ItemsSource="{Binding DataContext.ActivityLog, RelativeSource={RelativeSource AncestorType=Window}}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}"
                                               FontFamily="{StaticResource MonoFontFamily}"
                                               FontSize="12"
                                               Foreground="{DynamicResource ConsoleForegroundBrush}"
                                               TextWrapping="Wrap"
                                               Margin="0,2"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
