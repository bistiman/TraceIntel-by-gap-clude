<UserControl x:Class="TraceIntel.UI.Views.PingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1100">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource PanelCard}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,20,0">
                    <TextBlock Margin="0,0,0,8">
                        <Run Text="Target host or IP" FontWeight="SemiBold"/>
                        <Run Text=" · Status: " Foreground="{DynamicResource MutedForegroundBrush}"/>
                        <Run Text="{Binding PingStatus}" Foreground="{DynamicResource WarningBrush}" FontWeight="SemiBold"/>
                        <Run Text=" · Latency: " Foreground="{DynamicResource MutedForegroundBrush}"/>
                        <Run Text="{Binding PingLatency}" Foreground="{DynamicResource SuccessBrush}" FontWeight="SemiBold"/>
                    </TextBlock>
                    <TextBox Height="42"
                             Text="{Binding PingTarget, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="e.g. google.com or 8.8.8.8"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom">
                    <Button Content="Start Ping"
                            Command="{Binding StartPingCommand}"
                            Style="{StaticResource BaseButton}"
                            Width="140" Height="40"
                            Margin="0,0,10,0"/>
                    <Button Content="Stop"
                            Command="{Binding StopPingCommand}"
                            Style="{StaticResource DangerButton}"
                            Width="90" Height="40"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource CardBorder}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="ICMP ping output"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryBrush}"
                           Margin="0,0,0,12"/>

                <ListBox Grid.Row="1"
                         ItemsSource="{Binding PingOutput}"
                         FontFamily="{StaticResource MonoFontFamily}"
                         FontSize="{StaticResource FontSizeBody}"
                         Foreground="{DynamicResource ConsoleForegroundBrush}"
                         Background="{DynamicResource ConsoleBackgroundBrush}"
                         BorderBrush="{DynamicResource BorderBrush}"
                         BorderThickness="1"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
