<Window x:Class="TraceIntel.UI.MainWindow"
         xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
         xmlns:converters="clr-namespace:TraceIntel.UI.Converters" xmlns:local="clr-namespace:TraceIntel.UI.Views"
         Title="TRACE X" Height="800" Width="1400"
         Background="#1E1E2E" WindowStartupLocation="CenterScreen">

    <Window.InputBindings>
        <KeyBinding Key="Enter" Modifiers="Control" Command="{Binding StartCommand}" />
        <KeyBinding Key="Escape" Command="{Binding StopCommand}" />
        <KeyBinding Key="E" Modifiers="Control" Command="{Binding ExportCommand}" />
        <KeyBinding Key="F" Modifiers="Control" Command="Find" />
        <KeyBinding Key="L" Modifiers="Control" Command="Open" />
    </Window.InputBindings>

    <Window.CommandBindings>
        <CommandBinding Command="Find" Executed="Find_Executed" />
        <CommandBinding Command="Open" Executed="OpenTargets_Executed" />
    </Window.CommandBindings>

    <Window.Resources>
         <converters:BoolToStatusConverter x:Key="BoolToStatusConverter"/>
    <converters:InverseBoolConverter x:Key="InverseBoolConverter"/>
    <converters:JoinConverter x:Key="JoinConverter"/>
    <converters:StringEmptyToVisibilityConverter x:Key="StringEmptyToVisibilityConverter"/>
    <converters:RadioStringEqualsConverter x:Key="RadioStringEqualsConverter"/>
    <!-- این خط تغییر داده شود چون چنین کلاسی ندارید -->
    <!-- <converters:ProgressConverter x:Key="ProgressConverter"/> -->
    <converters:ProgressBarWidthConverter x:Key="ProgressBarWidthConverter"/>
    <converters:HopStatusBrushConverter x:Key="HopStatusBrushConverter"/>

    <DataTemplate x:Key="HopColumnHeaderTemplate">
        <StackPanel>
            <TextBlock Text="{Binding HopNumber, StringFormat=Hop {0}}"
                       FontWeight="Bold"
                       Foreground="White"/>
            <TextBox Height="28"
                     Margin="0,6,0,0"
                     Padding="6,2"
                     Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                     ToolTip="Filter this hop (IP)"/>
        </StackPanel>
    </DataTemplate>

    <DataTemplate x:Key="HopCellTemplate">
        <Border CornerRadius="6"
                Padding="6,3"
                Background="{Binding IsTimeout, Converter={StaticResource HopStatusBrushConverter}}"
                ToolTip="{Binding IP}">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="{Binding IP}" Foreground="White" />
                <TextBlock Text="{Binding LatencyText}"
                           Margin="8,0,0,0"
                           Foreground="#D7D7FF"
                           FontSize="12"/>
            </StackPanel>
        </Border>
    </DataTemplate>

    <DataTemplate x:Key="HopCellTemplatePrimary">
        <Border CornerRadius="7"
                Padding="8,4"
                Background="{Binding IsTimeout, Converter={StaticResource HopStatusBrushConverter}}"
                ToolTip="{Binding IP}">
            <StackPanel>
                <TextBlock Text="{Binding IP}"
                           Foreground="White"
                           FontWeight="SemiBold"/>
                <TextBlock Text="{Binding LatencyText}"
                           Foreground="#D7D7FF"
                           FontSize="12"
                           Margin="0,2,0,0"/>
            </StackPanel>
        </Border>
    </DataTemplate>

    <Style x:Key="PremiumRadio" TargetType="RadioButton">
        <Setter Property="Foreground" Value="#E0E0E0"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Margin" Value="0,0,12,0"/>
    </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#2D2D3A"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#6C5CE7"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="CaretBrush" Value="#6C5CE7"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="#6C5CE7"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="5" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#7C6CF7"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#4A4A5A"/>
                    <Setter Property="Foreground" Value="#808080"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="StopButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#E74C3C"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F75C4C"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ExportButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#27AE60"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#37BE70"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#2D2D3A"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#6C5CE7"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="RowBackground" Value="#2D2D3A"/>
            <Setter Property="AlternatingRowBackground" Value="#3A3A4A"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="#2D2D3A"/>
            <Style.Triggers>
                <!-- Soft red tint for early-fail traces -->
                <DataTrigger Binding="{Binding IsEarlyFail}" Value="True">
                    <Setter Property="Background" Value="#33262A"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#6C5CE7"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="BorderBrush" Value="#34344A"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ProgressBar">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Background" Value="#2D2D3A"/>
            <Setter Property="Foreground" Value="#6C5CE7"/>
            <Setter Property="BorderBrush" Value="#6C5CE7"/>
            <Setter Property="BorderThickness" Value="2"/>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <local:NavigationDrawer Grid.Row="0" Grid.Column="0" Grid.RowSpan="4" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Margin="-24,-24,12,-24"/>

        <!-- Header -->
        

        <!-- Input Section -->
        <Border Grid.Row="1" Grid.Column="1"
                Background="#242433"
                BorderBrush="#34344A"
                BorderThickness="1"
                CornerRadius="14"
                Padding="14"
                Margin="0,0,0,18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Targets (paste one per line, or comma/space separated)"
                               Foreground="#C9C9E6"
                               FontWeight="SemiBold"
                               Margin="0,0,0,10"/>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Domains Input (paste-friendly) -->
                        <Grid Grid.Column="0">
                            <TextBox x:Name="TargetsInputBox"
                                     Text="{Binding DomainsInput, UpdateSourceTrigger=PropertyChanged}"
                                     AcceptsReturn="True"
                                     AcceptsTab="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Disabled"
                                     MinHeight="110"
                                     MaxHeight="170"
                                     ToolTip="Examples: google.com | 8.8.8.8 | https://example.com/path"/>

                            <!-- Simple watermark -->
                            <TextBlock IsHitTestVisible="False"
                                       Margin="14,12,14,0"
                                       Foreground="#7F7FA3"
                                       Text="google.com&#x0a;8.8.8.8&#x0a;https://example.com/path"
                                       Visibility="{Binding DomainsInput, Converter={StaticResource StringEmptyToVisibilityConverter}}"/>
                        </Grid>

                        <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Top">
                            <TextBlock Text="Trace depth"
                                       Foreground="#C9C9E6"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,8"/>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <RadioButton Content="5 Hops"
                                             Style="{StaticResource PremiumRadio}"
                                             IsChecked="{Binding HopMode, Converter={StaticResource RadioStringEqualsConverter}, ConverterParameter=5}"/>
                                <RadioButton Content="Complete"
                                             Style="{StaticResource PremiumRadio}"
                                             IsChecked="{Binding HopMode, Converter={StaticResource RadioStringEqualsConverter}, ConverterParameter=Complete}"/>
                                <RadioButton Content="Custom"
                                             Style="{StaticResource PremiumRadio}"
                                             IsChecked="{Binding HopMode, Converter={StaticResource RadioStringEqualsConverter}, ConverterParameter=Custom}"/>
                            </StackPanel>

                            <TextBox Text="{Binding CustomMaxHops, UpdateSourceTrigger=PropertyChanged}"
                                     Width="120"
                                     Height="40"
                                     VerticalContentAlignment="Center"
                                     IsEnabled="{Binding HopMode, Converter={StaticResource RadioStringEqualsConverter}, ConverterParameter=Custom}"
                                     ToolTip="Custom max hops (1-255)"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Grid.Row="2"
                               Margin="0,10,0,0"
                               Foreground="#A8A8C8"
                               Text="Tip: You can paste a full list. Invalid/unresolvable entries will be skipped with a warning."/>
                </Grid>

                <!-- Actions -->
                <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Bottom">
                    <Button Content="Start Trace"
                            Command="{Binding StartCommand}"
                            IsEnabled="{Binding IsRunning, Converter={StaticResource InverseBoolConverter}}"
                            Width="140" Margin="0,0,0,10"/>
                    <Button Content="Stop"
                            Command="{Binding StopCommand}"
                            Style="{StaticResource StopButton}"
                            IsEnabled="{Binding IsRunning}"
                            Width="140" Margin="0,0,0,10"/>
                    <ComboBox ItemsSource="{Binding ExportFormats}"
                              SelectedItem="{Binding SelectedExportFormat}"
                              Width="140"
                              Height="32"
                              Margin="0,0,0,10"/>
                    <Button Content="Export Data"
                            Command="{Binding ExportCommand}"
                            Style="{StaticResource ExportButton}"
                            Width="140"
                            Margin="0,0,0,10"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Results -->
                <TabControl Grid.Row="2" Grid.Column="1" SelectedIndex="{Binding SelectedTabIndex}" TabStripPlacement="Top" Margin="0,0,0,20" Background="#1E1E2E" BorderThickness="0">
            <TabItem Header="Dashboard">
                <local:Dashboard DataContext="{Binding Dashboard}"/>
            </TabItem>
            <TabItem Header="Routing Table">
                <Grid Margin="0,10,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Vertical">
                            <TextBlock Text="Search (domain / destination / hop IP)"
                                       Foreground="#C9C9E6"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,6"/>
                            <TextBox x:Name="GlobalSearchBox"
                                     Height="40"
                                     Text="{Binding GlobalSearchText, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Search across domain, destination, and all hops (Ctrl+F to focus)"
                                     VerticalContentAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Grid.Column="1"
                                   Margin="12,0,0,0"
                                   VerticalAlignment="Center"
                                   Foreground="#E0E0E0"
                                   Text="{Binding HopColumnCount, StringFormat=Columns: {0} hops}"/>
                    </Grid>

                    <DataGrid x:Name="RoutingDataGrid"
                              Grid.Row="1"
                              ItemsSource="{Binding RoutingRowsView}"
                              AutoGenerateColumns="False"
                              CanUserSortColumns="True"
                              ClipboardCopyMode="ExcludeHeader"
                              SelectionUnit="CellOrRowHeader"
                              SelectionMode="Extended"
                              EnableRowVirtualization="True"
                              EnableColumnVirtualization="True"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Recycling"
                              ScrollViewer.CanContentScroll="True"
                              ColumnHeaderHeight="64"
                              RowHeaderWidth="0"
                              FrozenColumnCount="3"
                              HeadersVisibility="Column"
                              CanUserResizeColumns="True"
                              CanUserReorderColumns="True"
                              CanUserResizeRows="False">
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Copy" Command="Copy" />
                                <MenuItem Header="Copy with headers" Click="CopyWithHeaders_Click" />
                                <Separator />
                                <MenuItem Header="Perform DNS Recon" 
                                          Command="{Binding DataContext.RunReconFromTraceCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                          CommandParameter="{Binding SelectedItem.Domain, RelativeSource={RelativeSource AncestorType=DataGrid}}"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.RowDetailsTemplate>
                            <DataTemplate>
                                <Border Background="#242433" Padding="10" CornerRadius="8" Margin="0,6,0,6">
                                    <ItemsControl ItemsSource="{Binding Hops}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border CornerRadius="6"
                                                        Margin="0,0,8,8"
                                                        Padding="8,4"
                                                        Background="{Binding IsTimeout, Converter={StaticResource HopStatusBrushConverter}}"
                                                        ToolTip="{Binding HopNumber, StringFormat=Hop {0}}">
                                                    <TextBlock Foreground="White"
                                                               Text="{Binding IP}"/>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Border>
                            </DataTemplate>
                        </DataGrid.RowDetailsTemplate>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="By Hop">
                <Grid Margin="0,10,0,0">
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding HopSections}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>

                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#2D2D3A"
                                            BorderBrush="#6C5CE7"
                                            BorderThickness="2"
                                            CornerRadius="10"
                                            Margin="0,0,12,0"
                                            Padding="12"
                                            Width="320">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>

                                            <TextBlock Grid.Row="0"
                                                       FontSize="16"
                                                       FontWeight="Bold"
                                                       Foreground="#E0E0E0"
                                                       Text="{Binding HopNumber, StringFormat=Hop {0}}"/>

                                            <TextBox Grid.Row="1"
                                                     Margin="0,10,0,10"
                                                     Height="36"
                                                     Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                                                     ToolTip="Filter by domain or IP"/>

                                            <DataGrid Grid.Row="2"
                                                      ItemsSource="{Binding RowsView}"
                                                      HeadersVisibility="Column"
                                                      AutoGenerateColumns="False"
                                                      CanUserSortColumns="True">
                                                <DataGrid.Columns>
                                                    <DataGridTextColumn Header="Domain" Binding="{Binding Domain}" Width="*"/>
                                                    <DataGridTextColumn Header="IP" Binding="{Binding IP}" Width="140"/>
                                                </DataGrid.Columns>
                                            </DataGrid>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <TabItem Header="DNS Recon">
                <TabControl Background="#1E1E2E" BorderThickness="0" Margin="0,10,0,0">
                    
                    <!-- ====================== -->
                    <!-- SUB-TAB 1: DNS SCANNER -->
                    <!-- ====================== -->
                    <TabItem Header="DNS Scanner">
                        <Grid Margin="0,10,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- DNS Target & Options Section -->
                            <Border Grid.Row="0"
                                    Background="#242433"
                                    BorderBrush="#34344A"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="14"
                                    Margin="0,0,0,12">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Left Column: Input and Mode -->
                                    <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Vertical" Margin="0,0,12,0">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                            <TextBlock Text="Target Domain for DNS Recon" Foreground="#C9C9E6" FontWeight="SemiBold"/>
                                            <TextBlock Text=" | Status: " Foreground="#7F7FA3" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding DnsReconStatus}" Foreground="#6C5CE7" FontWeight="Bold"/>
                                        </StackPanel>
                                        <Grid>
                                            <TextBox x:Name="DnsReconTargetInput" Height="40"
                                                     Text="{Binding DnsReconTarget, UpdateSourceTrigger=PropertyChanged}"
                                                     ToolTip="Enter domain (e.g. google.com)"
                                                     VerticalContentAlignment="Center"/>
                                            <TextBlock IsHitTestVisible="False" Margin="14,12,14,0" Foreground="#7F7FA3"
                                                       Text="google.com"
                                                       Visibility="{Binding DnsReconTarget, Converter={StaticResource StringEmptyToVisibilityConverter}}"/>
                                        </Grid>
                                        
                                        <!-- DNS Scan Mode selector -->
                                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                            <TextBlock Text="Scan Mode: " Foreground="#C9C9E6" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                            <RadioButton Content="Quick" Style="{StaticResource PremiumRadio}" VerticalAlignment="Center"
                                                         IsChecked="{Binding DnsScanMode, Converter={StaticResource RadioStringEqualsConverter}, ConverterParameter=Standard}"/>
                                            <RadioButton Content="Deep" Style="{StaticResource PremiumRadio}" VerticalAlignment="Center"
                                                         IsChecked="{Binding DnsScanMode, Converter={StaticResource RadioStringEqualsConverter}, ConverterParameter=Deep}"/>
                                            <RadioButton Content="Custom" Style="{StaticResource PremiumRadio}" VerticalAlignment="Center"
                                                         IsChecked="{Binding DnsScanMode, Converter={StaticResource RadioStringEqualsConverter}, ConverterParameter=Custom}"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Middle Column: Query Types (Checkboxes for Complete Custom mode) -->
                                    <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Vertical" Margin="0,0,12,0"
                                                IsEnabled="{Binding DnsScanMode, Converter={StaticResource RadioStringEqualsConverter}, ConverterParameter=Custom}">
                                        <TextBlock Text="Manual Record Selection (Custom Mode)" Foreground="#C9C9E6" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                        
                                        <UniformGrid Columns="5" Rows="2">
                                            <CheckBox Content="A" Foreground="White" Margin="0,2,0,2" IsChecked="{Binding DnsQueryA}"/>
                                            <CheckBox Content="AAAA" Foreground="White" Margin="0,2,0,2" IsChecked="{Binding DnsQueryAAAA}"/>
                                            <CheckBox Content="MX" Foreground="White" Margin="0,2,0,2" IsChecked="{Binding DnsQueryMX}"/>
                                            <CheckBox Content="NS" Foreground="White" Margin="0,2,0,2" IsChecked="{Binding DnsQueryNS}"/>
                                            <CheckBox Content="CNAME" Foreground="White" Margin="0,2,0,2" IsChecked="{Binding DnsQueryCNAME}"/>
                                            <CheckBox Content="TXT" Foreground="White" Margin="0,2,0,2" IsChecked="{Binding DnsQueryTXT}"/>
                                            <CheckBox Content="SOA" Foreground="White" Margin="0,2,0,2" IsChecked="{Binding DnsQuerySOA}"/>
                                            <CheckBox Content="SRV" Foreground="White" Margin="0,2,0,2" IsChecked="{Binding DnsQuerySRV}"/>
                                            <CheckBox Content="CAA" Foreground="White" Margin="0,2,0,2" IsChecked="{Binding DnsQueryCAA}"/>
                                            <CheckBox Content="AXFR" Foreground="White" Margin="0,2,0,2" IsChecked="{Binding DnsQueryAXFR}" ToolTip="Attempt authoritative zone transfer"/>
                                        </UniformGrid>

                                        <!-- Subdomain brute force and Custom DNS server options -->
                                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                            <CheckBox Content="Brute Force Subdomains" Foreground="#FFB020" VerticalAlignment="Center" IsChecked="{Binding DnsBruteForce}"
                                                      ToolTip="Checks 40 common host subdomains for availability"/>
                                            <TextBlock Text=" | DNS Server:" Foreground="#C9C9E6" VerticalAlignment="Center" Margin="10,0,6,0"/>
                                            <TextBox Height="28" Width="130" Padding="4,2" Text="{Binding DnsCustomServer, UpdateSourceTrigger=PropertyChanged}"
                                                     ToolTip="Enter custom resolver IP (e.g. 8.8.8.8) or leave empty for default"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Right Column: Commands & Search -->
                                    <StackPanel Grid.Row="0" Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Bottom">
                                        <Button Content="Scan DNS" Command="{Binding StartDnsReconCommand}" Width="120" Height="40" Margin="0,0,8,0"/>
                                        <Button Content="Stop" Command="{Binding StopDnsReconCommand}" Style="{StaticResource StopButton}" Width="80" Height="40" Margin="0,0,8,0"/>
                                        <Button Content="Export" Command="{Binding ExportDnsReconCommand}" Style="{StaticResource ExportButton}" Width="110" Height="40"/>
                                    </StackPanel>

                                    <!-- Bottom Row: Inline Filter Search -->
                                    <Grid Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,10,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="300"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Filter Search: " Foreground="#A8A8C8" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <TextBox Grid.Column="1" Height="32" Padding="6,4" Text="{Binding DnsReconSearchText, UpdateSourceTrigger=PropertyChanged}"
                                                 ToolTip="Instant search through type, domain, value, details..."/>
                                    </Grid>
                                </Grid>
                            </Border>

                            <!-- DNS Records Display Area -->
                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="1*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Records Grid -->
                                <DataGrid Grid.Column="0"
                                          x:Name="DnsReconDataGrid"
                                          ItemsSource="{Binding DnsRecordsView}"
                                          SelectedItem="{Binding SelectedDnsRecord}"
                                          AutoGenerateColumns="False"
                                          CanUserSortColumns="True"
                                          HeadersVisibility="Column"
                                          Margin="0,0,12,0">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Type" Binding="{Binding RecordType}" Width="100" FontWeight="Bold"/>
                                        <DataGridTextColumn Header="Domain Name" Binding="{Binding Name}" Width="1.5*" />
                                        <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="2*" />
                                        <DataGridTextColumn Header="Details / Attributes" Binding="{Binding Details}" Width="2*" />
                                    </DataGrid.Columns>
                                </DataGrid>

                                <!-- Detail Panel -->
                                <Border Grid.Column="1"
                                        Background="#242433"
                                        BorderBrush="#34344A"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        Padding="16">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0"
                                                   Text="DNS Record Inspector"
                                                   FontSize="16"
                                                   FontWeight="Bold"
                                                   Foreground="#6C5CE7"
                                                   Margin="0,0,0,12"/>

                                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                            <StackPanel>
                                                <TextBlock Text="Record Type:" Foreground="#7F7FA3" FontSize="12" Margin="0,0,0,2"/>
                                                <TextBlock Text="{Binding SelectedDnsRecord.RecordType}" Foreground="White" FontSize="14" FontWeight="Bold" Margin="0,0,0,12"/>

                                                <TextBlock Text="Domain / Host:" Foreground="#7F7FA3" FontSize="12" Margin="0,0,0,2"/>
                                                <TextBlock Text="{Binding SelectedDnsRecord.Name}" Foreground="White" FontSize="14" Margin="0,0,0,12" TextWrapping="Wrap"/>

                                                <TextBlock Text="IP / Target Value:" Foreground="#7F7FA3" FontSize="12" Margin="0,0,0,2"/>
                                                <TextBox IsReadOnly="True"
                                                         Background="#2D2D3A"
                                                         BorderThickness="0"
                                                         Text="{Binding SelectedDnsRecord.Value, Mode=OneWay}"
                                                         FontSize="14"
                                                         Foreground="White"
                                                         TextWrapping="Wrap"
                                                         Padding="4"
                                                         Margin="0,0,0,12"/>

                                                <TextBlock Text="Parsed Properties &amp; TTL Details:" Foreground="#7F7FA3" FontSize="12" Margin="0,0,0,2"/>
                                                <TextBox IsReadOnly="True"
                                                         Background="#2D2D3A"
                                                         BorderThickness="0"
                                                         Height="180"
                                                         Text="{Binding SelectedDnsRecord.Details, Mode=OneWay}"
                                                         FontSize="14"
                                                         Foreground="#D7D7FF"
                                                         TextWrapping="Wrap"
                                                         VerticalScrollBarVisibility="Auto"
                                                         Padding="6"
                                                         AcceptsReturn="True"/>
                                            </StackPanel>
                                        </ScrollViewer>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Grid>
                    </TabItem>

                    <!-- ============================== -->
                    <!-- SUB-TAB 2: INTERACTIVE NSLOOKUP -->
                    <!-- ============================== -->
                    <TabItem Header="Interactive NSLOOKUP">
                        <Grid Margin="0,10,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Background="#242433" BorderBrush="#34344A" BorderThickness="1" CornerRadius="10" Padding="14" Margin="0,0,0,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Domain Query -->
                                    <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                        <TextBlock Text="Query Host / IP" Foreground="#C9C9E6" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                        <TextBox Height="40" Text="{Binding NslookupTarget, UpdateSourceTrigger=PropertyChanged}" ToolTip="Enter host (e.g. google.com)"/>
                                    </StackPanel>

                                    <!-- Query Type -->
                                    <StackPanel Grid.Column="1" Margin="0,0,12,0">
                                        <TextBlock Text="Record Type" Foreground="#C9C9E6" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                        <ComboBox Height="40" ItemsSource="{Binding NslookupRecordTypes}" SelectedItem="{Binding NslookupRecordType}"/>
                                    </StackPanel>

                                    <!-- DNS Server -->
                                    <StackPanel Grid.Column="2" Margin="0,0,12,0">
                                        <TextBlock Text="Resolver Server IP (Optional)" Foreground="#C9C9E6" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                        <TextBox Height="40" Text="{Binding NslookupServer, UpdateSourceTrigger=PropertyChanged}" ToolTip="e.g. 8.8.8.8 (Leave empty for default)"/>
                                    </StackPanel>

                                    <!-- Query Command -->
                                    <StackPanel Grid.Column="3" VerticalAlignment="Bottom">
                                        <Button Content="Run NSLOOKUP" Command="{Binding RunNslookupCommand}" Width="160" Height="40"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Border Grid.Row="1" Background="#242433" BorderBrush="#34344A" BorderThickness="1" CornerRadius="10" Padding="16">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                                        <TextBlock Text="DNS Query Audit Output (dig format)" FontSize="14" FontWeight="Bold" Foreground="#6C5CE7"/>
                                        <TextBlock Text=" | Status: " Foreground="#7F7FA3"/>
                                        <TextBlock Text="{Binding NslookupStatus}" Foreground="#FFB020" FontWeight="Bold"/>
                                    </StackPanel>
                                    <TextBox Grid.Row="1" IsReadOnly="True" AcceptsReturn="True"
                                             Background="#1A1A24" Foreground="#85F585" BorderThickness="0" FontFamily="Consolas, Courier New" FontSize="13"
                                             Text="{Binding NslookupResultText}" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" Padding="10"/>
                                </Grid>
                            </Border>
                        </Grid>
                    </TabItem>

                    <!-- ====================== -->
                    <!-- SUB-TAB 3: WHOIS LOOKUP -->
                    <!-- ====================== -->
                    <TabItem Header="WHOIS Lookup">
                        <Grid Margin="0,10,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Background="#242433" BorderBrush="#34344A" BorderThickness="1" CornerRadius="10" Padding="14" Margin="0,0,0,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Host input -->
                                    <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                            <TextBlock Text="Target Domain or IP Address" Foreground="#C9C9E6" FontWeight="SemiBold"/>
                                            <TextBlock Text=" | Status: " Foreground="#7F7FA3"/>
                                            <TextBlock Text="{Binding WhoisStatus}" Foreground="#FFB020" FontWeight="Bold"/>
                                        </StackPanel>
                                        <TextBox Height="40" Text="{Binding WhoisTarget, UpdateSourceTrigger=PropertyChanged}" ToolTip="Enter domain (e.g. google.com) or IPv4 (e.g. 8.8.8.8)"/>
                                    </StackPanel>

                                    <!-- Lookup Actions -->
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom">
                                        <Button Content="Perform WHOIS" Command="{Binding StartWhoisCommand}" Width="160" Height="40" Margin="0,0,8,0"/>
                                        <Button Content="Stop" Command="{Binding StopWhoisCommand}" Style="{StaticResource StopButton}" Width="80" Height="40"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Border Grid.Row="1" Background="#242433" BorderBrush="#34344A" BorderThickness="1" CornerRadius="10" Padding="16">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Text="Domain Registration WHOIS Registry Output" FontSize="14" FontWeight="Bold" Foreground="#6C5CE7" Margin="0,0,0,10"/>
                                    <TextBox Grid.Row="1" IsReadOnly="True" AcceptsReturn="True"
                                             Background="#1A1A24" Foreground="#D1D1E6" BorderThickness="0" FontFamily="Consolas, Courier New" FontSize="13"
                                             Text="{Binding WhoisResultText}" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" Padding="10"/>
                                </Grid>
                            </Border>
                        </Grid>
                    </TabItem>
                </TabControl>
            </TabItem>

            <!-- ============================== -->
            <!-- TAB 5: SYSTEM CONFIGURATION    -->
            <!-- ============================== -->
            <TabItem Header="Settings">
                <Grid Margin="0,15,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="400"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="#242433" BorderBrush="#34344A" BorderThickness="1" CornerRadius="14" Padding="20" Margin="0,0,15,0">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="System Settings &amp; Engine Configuration" FontSize="18" FontWeight="Bold" Foreground="#6C5CE7" Margin="0,0,0,15"/>

                                <!-- Traceroute Concurrency -->
                                <TextBlock Text="Maximum Concurrent Traceroutes" Foreground="#C9C9E6" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <Grid Margin="0,0,0,20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="60"/>
                                    </Grid.ColumnDefinitions>
                                    <Slider Grid.Column="0" Minimum="1" Maximum="50" TickFrequency="1" IsSnapToTickEnabled="True" 
                                            Value="{Binding SettingsParallelism}" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding SettingsParallelism}" Foreground="White" FontSize="14" 
                                               HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                                </Grid>

                                <!-- Timeout Slider -->
                                <TextBlock Text="Traceroute / DNS Probe Timeout (milliseconds)" Foreground="#C9C9E6" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <Grid Margin="0,0,0,20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="80"/>
                                    </Grid.ColumnDefinitions>
                                    <Slider Grid.Column="0" Minimum="200" Maximum="5000" TickFrequency="100" IsSnapToTickEnabled="True" 
                                            Value="{Binding SettingsTimeoutMs}" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding SettingsTimeoutMs, StringFormat={}{0} ms}" Foreground="White" FontSize="14" 
                                               HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                                </Grid>

                                <!-- Custom default DNS Server -->
                                <TextBlock Text="Default Custom DNS Server" Foreground="#C9C9E6" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <TextBox Height="38" Text="{Binding SettingsDefaultDnsServer, UpdateSourceTrigger=PropertyChanged}" 
                                         ToolTip="The default server to prefill DNS Custom options (e.g. 1.1.1.1)"/>
                                <TextBlock Text="Tip: System will query local network resolvers if left blank." Foreground="#7F7FA3" Margin="0,4,0,20" FontSize="12"/>

                                <!-- Cache Toggle -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                    <CheckBox Content="Enable DNS &amp; IP Geo Cache Lookups" Foreground="White" FontSize="14" IsChecked="{Binding SettingsEnableCache}"/>
                                </StackPanel>

                                <!-- Default Export Folder -->
                                <TextBlock Text="Default Export Data Path" Foreground="#C9C9E6" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <TextBox Height="38" Text="{Binding SettingsDefaultExportPath, UpdateSourceTrigger=PropertyChanged}" 
                                         ToolTip="Custom folder directory to save reports"/>
                                
                            </StackPanel>
                        </ScrollViewer>
                    </Border>

                    <!-- Sidebar Info / Guides -->
                    <Border Grid.Column="1" Background="#242433" BorderBrush="#34344A" BorderThickness="1" CornerRadius="14" Padding="20">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="TRACE X Guide" FontSize="18" FontWeight="Bold" Foreground="#FFB020" Margin="0,0,0,15"/>
                            
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <TextBlock Text="Traceroute Diagnostics" FontSize="14" FontWeight="Bold" Foreground="White" Margin="0,0,0,6"/>
                                    <TextBlock Text="Utilizes local ICMP packets to map intermediate router nodes. Quick Trace targets 5 hops for standard gateways. Complete matches 30 hops. Early Path Block occurs when security firewalls drop ICMP echo requests immediately." 
                                               Foreground="#A8A8C8" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,15"/>

                                    <TextBlock Text="DNS Enumeration &amp; WHOIS" FontSize="14" FontWeight="Bold" Foreground="White" Margin="0,0,0,6"/>
                                    <TextBlock Text="Scans authoritative domains. Subdomain Brute Force tests top common production hosts for sub-site discovery. Zone Transfer (AXFR) will attempt full database replication, which usually returns REFUSED on standard secure servers." 
                                               Foreground="#A8A8C8" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,15"/>

                                    <TextBlock Text="NSLOOKUP (dig)" FontSize="14" FontWeight="Bold" Foreground="White" Margin="0,0,0,6"/>
                                    <TextBlock Text="Queries exact DNS records manually. Interactive NSLOOKUP allows testing specific name servers (like OpenDNS or Quad9) directly inside TRACE X." 
                                               Foreground="#A8A8C8" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,15"/>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Status Bar -->
        <Grid Grid.Row="3" Grid.Column="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" VerticalAlignment="Center" Margin="0,0,20,0">
                <Run Text="Status: "/>
                <Run Text="{Binding Status}" FontWeight="Bold" Foreground="#6C5CE7"/>
            </TextBlock>

            <ProgressBar Grid.Column="1" Value="{Binding Progress}" Maximum="100"/>

            <TextBlock Grid.Column="2" VerticalAlignment="Center" Margin="20,0,20,0">
                <Run Text="Total traced domains: "/>
                <Run Text="{Binding SuccessfulTracesCount, Mode=OneWay}" FontWeight="Bold" Foreground="#6C5CE7"/>
            </TextBlock>

            <TextBlock Grid.Column="3" VerticalAlignment="Center" Margin="0,0,0,0">
                <Run Text="Progress: "/>
                <Run Text="{Binding Progress, StringFormat={}{0:F1}%}" FontWeight="Bold" Foreground="#6C5CE7"/>
            </TextBlock>
        </Grid>
    </Grid>
</Window>
