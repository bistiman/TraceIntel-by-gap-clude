<Window x:Class="TraceIntel.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:TraceIntel.UI.Views"
        xmlns:vms="clr-namespace:TraceIntel.UI.ViewModels"
        Title="TRACE X - Advanced Security Intel Suite"
        Height="850"
        Width="1440"
        Background="{DynamicResource BackgroundBrush}"
        WindowStartupLocation="CenterScreen">

    <Window.InputBindings>
        <KeyBinding Key="Enter" Modifiers="Control" Command="{Binding TraceVM.StartCommand}" />
        <KeyBinding Key="Escape" Command="{Binding TraceVM.StopCommand}" />
        <KeyBinding Key="E" Modifiers="Control" Command="{Binding TraceVM.ExportCommand}" />
    </Window.InputBindings>

    <Window.Resources>
        <!-- Map ViewModels to Views Programmatically using standard DataTemplates -->
        <DataTemplate DataType="{x:Type vms:DashboardViewModel}">
            <local:Dashboard />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vms:TraceViewModel}">
            <local:TraceView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vms:DomainIntelViewModel}">
            <local:DomainIntelView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vms:SettingsViewModel}">
            <local:SettingsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vms:PingViewModel}">
            <local:PingView />
        </DataTemplate>
    </Window.Resources>

    <Grid Margin="0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <local:NavigationDrawer Grid.Column="0" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" />

        <Border Grid.Column="1"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="20"
                Padding="24"
                Margin="18">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,20">
                    <TextBlock Text="{Binding CurrentPageTitle}" Style="{StaticResource SectionTitle}" />
                    <TextBlock Text="{Binding CurrentPageSubtitle}" Style="{StaticResource SectionSubtitle}" />
                </StackPanel>

                <ContentControl Grid.Row="1" Content="{Binding CurrentPageViewModel}" />
            </Grid>
        </Border>
    </Grid>
</Window>
